{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ],
  "functions": {
    "api/seo.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/api/sitemap",
      "destination": "/api/tools.ts?tool=sitemap"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/tools.ts?tool=sitemap"
    },
    {
      "source": "/api/tools/:tool",
      "destination": "/api/tools.ts?tool=:tool"
    },
    {
      "source": "/api/blog/posts",
      "destination": "/api/blog.ts?action=posts"
    },
    {
      "source": "/api/blog/post",
      "destination": "/api/blog.ts?action=post"
    },
    {
      "source": "/api/support/chat",
      "destination": "/api/support.ts?action=chat"
    },
    {
      "source": "/api/support/complaint",
      "destination": "/api/support.ts?action=complaint"
    },
    {
      "source": "/tools/:tool",
      "destination": "/api/seo.ts?type=tool&slug=:tool"
    },
    {
      "source": "/tools",
      "destination": "/api/seo.ts?type=tools-home"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/seo.ts?type=blog&slug=:slug"
    },
    {
      "source": "/blog",
      "destination": "/api/seo.ts?type=blog-home"
    },
    {
      "source": "/api/health",
      "destination": "/api/tools.ts?tool=health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}