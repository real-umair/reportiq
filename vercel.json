{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/sitemap",
      "destination": "/api/tools.ts?tool=sitemap"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/tools.ts?tool=sitemap"
    },
    {
      "source": "/api/tools/:tool",
      "destination": "/api/tools.ts?tool=:tool"
    },
    {
      "source": "/api/blog/posts",
      "destination": "/api/blog.ts?action=posts"
    },
    {
      "source": "/api/blog/post",
      "destination": "/api/blog.ts?action=post"
    },
    {
      "source": "/api/support/chat",
      "destination": "/api/support.ts?action=chat"
    },
    {
      "source": "/api/support/complaint",
      "destination": "/api/support.ts?action=complaint"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}